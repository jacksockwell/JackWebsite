<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jacksockwell</title>
  <style>
    :root{
      --bg:#43496b;
      --pink:#ef63ab;
      --yellow:#ffe900;
      --orange:#ff7a00;
      --cyan:#00d8ff;
      --purple:#7b39ff;
      --white:#fff8ef;
      --black:#171717;
    }

    *{box-sizing:border-box}

    html{
      scroll-behavior:smooth;
    }

    body{
      margin:0;
      background:var(--bg);
      color:var(--white);
      font-family: Arial, Helvetica, sans-serif;
      min-height:100vh;
    }

    a{
      color:inherit;
    }

    .frame{
      min-height:100vh;
      border:4px solid var(--yellow);
      padding:18px;
      position:relative;
      overflow:hidden;
      isolation:isolate;
    }

    .floating-shape{
      position:absolute;
      border:4px solid var(--yellow);
      pointer-events:none;
      opacity:.16;
      will-change:transform;
      transition:transform .08s linear;
      z-index:0;
    }

    .shape-a{
      width:260px;
      height:260px;
      right:-80px;
      top:90px;
      background:linear-gradient(135deg,var(--orange),var(--pink));
      transform:rotate(12deg);
    }

    .shape-b{
      width:180px;
      height:180px;
      left:-50px;
      bottom:40px;
      background:var(--cyan);
      transform:rotate(-16deg);
    }

    .shape-c{
      width:120px;
      height:120px;
      right:16%;
      bottom:11%;
      background:var(--purple);
      opacity:.12;
      transform:rotate(8deg);
    }

    .wrap{
      max-width:1400px;
      margin:0 auto;
      position:relative;
      z-index:1;
    }

    .top-banner{
      background:var(--pink);
      border:4px solid var(--yellow);
      padding:28px 30px;
      margin-bottom:28px;
      box-shadow:12px 12px 0 rgba(0,0,0,.18);
    }

    .eyebrow{
      color:var(--yellow);
      font-family: Rockwell, "Rockwell Nova", "Roboto Slab", Georgia, serif;
      font-size:clamp(1rem,2vw,1.35rem);
      margin:0 0 10px 0;
      letter-spacing:.04em;
      text-transform:uppercase;
    }

    .title{
      margin:0;
      font-family: Rockwell, "Rockwell Nova", "Roboto Slab", Georgia, serif;
      font-size:clamp(2.2rem,7vw,5.2rem);
      line-height:.95;
      color:var(--white);
      text-transform:uppercase;
      text-shadow:4px 4px 0 rgba(0,0,0,.18);
    }

    .subtitle{
      margin:14px 0 0;
      max-width:850px;
      font-size:clamp(1rem,2vw,1.2rem);
      color:#fff1b8;
    }

    .grid{
      display:grid;
      grid-template-columns:1.08fr 1fr;
      gap:34px;
      align-items:start;
    }

    .card{
      border:4px solid var(--yellow);
      box-shadow:12px 12px 0 rgba(0,0,0,.18);
    }

    .pink-card{
      background:var(--pink);
      min-height:280px;
      padding:28px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .pink-card h2,
    .yellow-card h2,
    .gallery-title,
    .mini-card h3{
      margin:0 0 14px;
      font-family: Rockwell, "Rockwell Nova", "Roboto Slab", Georgia, serif;
      text-transform:uppercase;
      line-height:1;
    }

    .pink-card h2{
      font-size:clamp(1.8rem,4vw,3rem);
      color:var(--yellow);
    }

    .pink-card p{
      margin:0 0 22px;
      color:#fff8ef;
      font-size:1.05rem;
      max-width:560px;
    }

    .actions{
      display:flex;
      flex-wrap:wrap;
      gap:14px;
    }

    .btn{
      text-decoration:none;
      padding:14px 18px;
      border:3px solid var(--yellow);
      color:var(--black);
      background:var(--yellow);
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.04em;
      box-shadow:6px 6px 0 rgba(0,0,0,.18);
      transition:transform .15s ease, box-shadow .15s ease, background .15s ease;
      display:inline-block;
    }

    .btn.alt{
      background:transparent;
      color:var(--white);
    }

    .btn:hover{
      transform:translate(-3px,-3px);
      box-shadow:10px 10px 0 rgba(0,0,0,.18);
    }

    .yellow-card{
      background:var(--yellow);
      color:var(--black);
      min-height:455px;
      padding:28px;
      position:relative;
    }

    .yellow-card h2{
      font-size:clamp(2rem,4.5vw,3.4rem);
    }

    .yellow-card p{
      max-width:470px;
      font-size:1.04rem;
      line-height:1.5;
    }

    .tag{
      display:inline-block;
      margin-top:10px;
      padding:10px 14px;
      border:3px solid var(--black);
      font-weight:900;
      text-transform:uppercase;
      background:var(--pink);
      color:var(--white);
    }

    .gallery{
      margin-top:30px;
      padding:28px;
      background:#4e5377;
    }

    .gallery-title{
      font-size:clamp(1.8rem,4vw,3rem);
      color:var(--yellow);
      margin-bottom:10px;
    }

    .gallery-sub{
      margin:0 0 20px;
      max-width:850px;
      line-height:1.5;
    }

    .photo-grid{
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:22px;
    }

    .photo{
      background:#2f3452;
      min-height:240px;
      position:relative;
      overflow:hidden;
      will-change:transform;
      transition:transform .15s ease;
    }

    .photo:hover{
      transform:translate(-2px,-2px);
    }

    .photo img{
      width:112%;
      height:112%;
      object-fit:cover;
      position:absolute;
      left:50%;
      top:50%;
      transform:translate(-50%,-50%);
      transition:transform .08s linear;
      will-change:transform;
    }

    .photo-label{
      position:absolute;
      left:14px;
      bottom:14px;
      background:rgba(23,23,23,.78);
      color:var(--yellow);
      border:3px solid var(--yellow);
      padding:8px 10px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.04em;
      z-index:2;
    }

    .socials{
      margin-top:28px;
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:22px;
    }

    .social-card{
      min-height:180px;
      padding:22px;
    }

    .social-card h3{
      margin:0 0 12px;
      font-family: Rockwell, "Rockwell Nova", "Roboto Slab", Georgia, serif;
      text-transform:uppercase;
      line-height:1;
      font-size:1.4rem;
    }

    .social-card p{
      margin:0 0 16px;
      line-height:1.5;
    }

    .social-card.x{
      background:var(--pink);
      color:var(--white);
    }

    .social-card.youtube{
      background:var(--yellow);
      color:var(--black);
    }

    .social-card.artstation{
      background:var(--orange);
      color:var(--black);
    }

    .lower{
      margin-top:28px;
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:22px;
    }

    .mini-card{
      min-height:160px;
      padding:20px;
      background:#515779;
      color:var(--white);
    }

    .mini-card:nth-child(2){
      background:var(--orange);
      color:var(--black);
    }

    .mini-card:nth-child(3){
      background:var(--purple);
    }

    .mini-card h3{
      font-size:1.35rem;
    }

    .mini-card p{
      margin:0;
      line-height:1.45;
    }

    @media (max-width: 1000px){
      .grid,
      .photo-grid,
      .socials,
      .lower{
        grid-template-columns:1fr;
      }

      .yellow-card{
        min-height:320px;
      }

      .pink-card{
        min-height:auto;
      }

      .photo{
        min-height:300px;
      }
    }
  </style>
</head>
<body>
  <main class="frame" id="siteFrame">
    <div class="floating-shape shape-a" data-depth="14"></div>
    <div class="floating-shape shape-b" data-depth="8"></div>
    <div class="floating-shape shape-c" data-depth="12"></div>

    <div class="wrap">
      <section class="top-banner card">
        <p class="eyebrow">Blocky / Artistic / Loud</p>
        <h1 class="title">Jack Sockwell</h1>
        <p class="subtitle">
          3D models, weird art, funny edits, and loud visuals in one place.
        </p>
      </section>

      <section class="grid">
        <article class="pink-card card">
          <div>
            <h2>About this space</h2>
            <p>
              This layout keeps the rough blocky shape from your sketch, but now it is built to hold real content. Use this area as your intro, updates, commission info, or whatever you want people to see first.
            </p>
          </div>

          <div class="actions">
            <a class="btn" href="#gallery">See Work</a>
            <a class="btn alt" href="#socials">Socials</a>
          </div>
        </article>

        <article class="yellow-card card">
          <h2>Featured block</h2>
          <p>
            This big square is perfect for a featured project, hero image, newest model, or some really loud artwork that reacts slightly to the mouse.
          </p>
          <span class="tag">Mouse parallax ready</span>
        </article>
      </section>

      <section class="gallery card" id="gallery">
        <h2 class="gallery-title">Art / Models / Photos</h2>
        <p class="gallery-sub">
          Drop your own images into these blocks and they will shift very slightly with your mouse. The effect is intentionally subtle so it feels clean instead of gimmicky.
        </p>

        <div class="photo-grid">
          <figure class="photo card parallax-item" data-depth="10">
            <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1200&q=80" alt="Placeholder artwork 1" />
            <figcaption class="photo-label">Project One</figcaption>
          </figure>

          <figure class="photo card parallax-item" data-depth="14">
            <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1200&q=80" alt="Placeholder artwork 2" />
            <figcaption class="photo-label">Project Two</figcaption>
          </figure>

          <figure class="photo card parallax-item" data-depth="18">
            <img src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&w=1200&q=80" alt="Placeholder artwork 3" />
            <figcaption class="photo-label">Project Three</figcaption>
          </figure>
        </div>
      </section>

      <section class="socials" id="socials">
        <article class="social-card x card">
          <h3>X / Twitter</h3>
          <p>
            JackSockwellP — bio snippets found publicly describe you as JackahhSocks and say you make funny video edits and 3D models.
          </p>
          <a class="btn alt" href="https://x.com/JackSockwellP" target="_blank" rel="noopener noreferrer">Open X</a>
        </article>

        <article class="social-card youtube card">
          <h3>YouTube</h3>
          <p>
            Public results point to a YouTube channel tied to JackahhSocks / JackDoesGamez, with modeling livestreams and the same funny edits + 3D models vibe.
          </p>
          <a class="btn" href="https://www.youtube.com/@JackDoesGamez" target="_blank" rel="noopener noreferrer">Open YouTube</a>
        </article>

        <article class="social-card artstation card">
          <h3>ArtStation</h3>
          <p>
            Your ArtStation appears to be polygonparadise, where the profile says you are a 3D generalist and shows portfolio work like stylized/cartoon projects and commissions.
          </p>
          <a class="btn" href="https://www.artstation.com/polygonparadise" target="_blank" rel="noopener noreferrer">Open ArtStation</a>
        </article>
      </section>

      <section class="lower">
        <article class="mini-card card">
          <h3>Blocky Layout</h3>
          <p>Everything stays chunky and framed so the bright colors feel like a style choice, not a mess.</p>
        </article>

        <article class="mini-card card">
          <h3>Parallax Photos</h3>
          <p>Your images can move just a little with the mouse. Easy to tune stronger or weaker later.</p>
        </article>

        <article class="mini-card card">
          <h3>Next Step</h3>
          <p>Replace the placeholder images and I can turn this into your actual homepage with your real projects and links.</p>
        </article>
      </section>
    </div>
  </main>

  <script>
    const frame = document.getElementById('siteFrame');
    const parallaxItems = document.querySelectorAll('.parallax-item, .floating-shape');
    let mouseX = 0;
    let mouseY = 0;
    let currentX = 0;
    let currentY = 0;

    function updateParallax(){
      currentX += (mouseX - currentX) * 0.08;
      currentY += (mouseY - currentY) * 0.08;

      parallaxItems.forEach((item) => {
        const depth = Number(item.dataset.depth || 10);
        const moveX = currentX / depth;
        const moveY = currentY / depth;

        if(item.classList.contains('photo')){
          const img = item.querySelector('img');
          if(img){
            img.style.transform = `translate(calc(-50% + ${moveX}px), calc(-50% + ${moveY}px)) scale(1.03)`;
          }
        } else {
          const baseRotation =
            item.classList.contains('shape-a') ? ' rotate(12deg)' :
            item.classList.contains('shape-b') ? ' rotate(-16deg)' :
            item.classList.contains('shape-c') ? ' rotate(8deg)' : '';
          item.style.transform = `translate(${moveX}px, ${moveY}px)` + baseRotation;
        }
      });

      requestAnimationFrame(updateParallax);
    }

    frame.addEventListener('mousemove', (event) => {
      const rect = frame.getBoundingClientRect();
      const x = event.clientX - rect.left;
      const y = event.clientY - rect.top;
      mouseX = ((x / rect.width) - 0.5) * 22;
      mouseY = ((y / rect.height) - 0.5) * 22;
    });

    frame.addEventListener('mouseleave', () => {
      mouseX = 0;
      mouseY = 0;
    });

    updateParallax();
  </script>
</body>
</html>
